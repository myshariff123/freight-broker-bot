FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY listing_sniper_requirements.txt .
RUN pip install --no-cache-dir -r listing_sniper_requirements.txt

COPY listing_sniper/ ./listing_sniper/
RUN python -c "from listing_sniper.main import run"

CMD ["python", "-u", "-m", "listing_sniper.main"]
