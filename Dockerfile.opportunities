FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY opportunities_requirements.txt .
RUN pip install --no-cache-dir -r opportunities_requirements.txt

COPY price_glitch/ ./price_glitch/
COPY classaction/ ./classaction/
COPY odds_arb/ ./odds_arb/
COPY opportunities_main.py .

CMD ["python", "-u", "opportunities_main.py"]
