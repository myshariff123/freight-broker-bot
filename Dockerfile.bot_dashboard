FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ libpq-dev python3-dev libffi-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY bot_dashboard_requirements.txt .
RUN pip install --no-cache-dir -r bot_dashboard_requirements.txt

COPY bot_dashboard/ ./bot_dashboard/

CMD ["uvicorn", "bot_dashboard.main:app", "--host", "0.0.0.0", "--port", "8081"]
